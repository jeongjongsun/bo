<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.shopeasy.mapper.OmConfigMapper">

    <select id="selectMaxPasswordFailCount" resultType="java.lang.Integer">
        SELECT max_password_fail_count
          FROM om_config_m
         WHERE id = 1
         LIMIT 1
    </select>

</mapper>
